# ─────────────────────────────────────────────
#  GameShop Bot — Environment Variables
#  Скопируй в .env и заполни реальными значениями
# ─────────────────────────────────────────────

# ── Название магазина (меняется здесь — применяется везде) ──
SHOP_NAME="GameShop"
SHOP_TAGLINE="Игровой донат и виртуальные товары"
SHOP_SUPPORT_USERNAME="your_support_username"

# ── Telegram ──
BOT_TOKEN="1234567890:AAF..."
ADMIN_BOT_TOKEN="0987654321:AAF..."   # Отдельный бот для админов (опционально)
WEBHOOK_HOST="https://yourdomain.com"
WEBHOOK_PATH="/webhook/bot"
WEBHOOK_SECRET="your_webhook_secret_32chars"

# ── Mini App ──
MINIAPP_URL="https://yourdomain.com/app"

# ── PostgreSQL ──
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=gameshop
POSTGRES_PASSWORD=supersecretpassword
POSTGRES_DB=gameshop
DATABASE_URL="postgresql+asyncpg://gameshop:supersecretpassword@db:5432/gameshop"

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redispassword
REDIS_URL="redis://:redispassword@redis:6379/0"
CELERY_BROKER_URL="redis://:redispassword@redis:6379/1"
CELERY_RESULT_BACKEND="redis://:redispassword@redis:6379/2"

# ── JWT ──
JWT_SECRET_KEY="your_jwt_secret_min_32_chars_here"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Оплата: ЮKassa ──
YUKASSA_SHOP_ID="your_shop_id"
YUKASSA_SECRET_KEY="your_secret_key"

# ── Оплата: CryptoBot (USDT/TON) ──
CRYPTOBOT_TOKEN="your_cryptobot_token"
CRYPTOBOT_NETWORK="mainnet"   # или testnet

# ── Шифрование ключей выдачи ──
ENCRYPTION_KEY="your_32_byte_fernet_key_base64=="

# ── Хранилище медиа (S3/MinIO) ──
S3_ENDPOINT="https://s3.yourdomain.com"
S3_ACCESS_KEY="your_access_key"
S3_SECRET_KEY="your_secret_key"
S3_BUCKET="gameshop-media"
S3_REGION="us-east-1"

# ── Настройки приложения ──
DEBUG=false
LOG_LEVEL="INFO"
ENVIRONMENT="production"   # development | production

# ── Лимиты ──
RATE_LIMIT_CLIENT=30       # запросов в минуту для клиентов
RATE_LIMIT_ADMIN=100       # запросов в минуту для админов
ABANDONED_CART_HOURS=1     # через сколько часов напомнить о корзине
CART_PRICE_RESERVE_HOURS=24  # резервирование цены в корзине
